#!/usr/bin/env python3
"""mnemo-skill — effectiveness tracking + curation for mnemo-forged skills.

The thing Hermes never did: *measure* whether a forged skill earns its keep,
and prune the ones that don't. Operates ONLY on skills whose frontmatter
carries `forged-by: mnemo` — human-authored skills are never touched.

Each forged skill's frontmatter carries effectiveness metadata:
    forged-by: mnemo
    forged: 2026-06-01          # date created
    uses: 3                     # times the skill actually fired in a session
    last-used: 2026-06-08       # or 'never'
    contradicted: false         # set true when a later correction conflicts

Usage:
  mnemo-skill list                       # table of forged skills + metrics
  mnemo-skill touch  <name>              # record that the skill fired (uses += 1)
  mnemo-skill flag   <name> [reason]     # mark contradicted (a correction conflicts)
  mnemo-skill unflag <name>              # clear the contradicted flag
  mnemo-skill gc [--apply]               # surface (or prune) dead/contradicted skills
"""
import sys, os, re
from pathlib import Path
from datetime import datetime, timezone

SKILLS_DIR = Path(os.environ.get("MNEMO_SKILLS_DIR", str(Path.home() / ".claude" / "skills")))
MNEMO_HOME = Path(os.environ.get("MNEMO_HOME", str(Path.home() / ".mnemo")))
GC_DAYS = int(os.environ.get("MNEMO_GC_DAYS", "21"))
MARKER = "forged-by: mnemo"


def _today():
    return datetime.now(timezone.utc).date().isoformat()


def _age_days(iso):
    try:
        d = datetime.fromisoformat(iso).date()
        return (datetime.now(timezone.utc).date() - d).days
    except Exception:
        return None


def _skill_files():
    if not SKILLS_DIR.exists():
        return []
    return sorted(SKILLS_DIR.glob("*/SKILL.md"))


def _split(text):
    """Return (frontmatter_dict, fm_lines, body) for a SKILL.md, or (None,..)."""
    if not text.startswith("---"):
        return None, [], text
    parts = text.split("---", 2)
    if len(parts) < 3:
        return None, [], text
    fm_raw = parts[1]
    body = parts[2]
    fm = {}
    for line in fm_raw.splitlines():
        m = re.match(r"^([A-Za-z0-9_-]+):\s?(.*)$", line)
        if m:
            fm[m.group(1)] = m.group(2).strip()
    return fm, fm_raw.splitlines(), body


def _is_forged(fm):
    return fm is not None and fm.get("forged-by", "").strip() == "mnemo"


def _rewrite(path, fm):
    """Rewrite SKILL.md preserving body, replacing the frontmatter from fm dict."""
    text = path.read_text(encoding="utf-8")
    _, _, body = _split(text)
    # Stable key order; keep any unknown keys after the known ones.
    order = ["name", "description", "forged-by", "forged", "uses", "last-used", "contradicted"]
    keys = [k for k in order if k in fm] + [k for k in fm if k not in order]
    fm_lines = "\n".join(f"{k}: {fm[k]}" for k in keys)
    path.write_text(f"---\n{fm_lines}\n---{body}", encoding="utf-8")


def _find(name):
    p = SKILLS_DIR / name / "SKILL.md"
    if not p.exists():
        sys.exit(f"error: no skill '{name}' at {p}")
    fm, _, _ = _split(p.read_text(encoding="utf-8"))
    if not _is_forged(fm):
        sys.exit(f"error: '{name}' is not a mnemo-forged skill — refusing to touch it")
    return p, fm


def _ensure_defaults(fm):
    fm.setdefault("forged", _today())
    fm.setdefault("uses", "0")
    fm.setdefault("last-used", "never")
    fm.setdefault("contradicted", "false")
    return fm


def cmd_list():
    rows = []
    for p in _skill_files():
        fm, _, _ = _split(p.read_text(encoding="utf-8"))
        if not _is_forged(fm):
            continue
        _ensure_defaults(fm)
        rows.append((p.parent.name, fm.get("uses", "0"), fm.get("last-used", "never"),
                     fm.get("forged", "?"), fm.get("contradicted", "false")))
    if not rows:
        print("(no mnemo-forged skills yet)")
        return
    w = max(len(r[0]) for r in rows)
    print(f"{'SKILL'.ljust(w)}  USES  LAST-USED   FORGED      FLAG")
    for name, uses, last, forged, contra in sorted(rows, key=lambda r: -int(r[1] or 0)):
        flag = "⚠ contradicted" if contra == "true" else ""
        print(f"{name.ljust(w)}  {str(uses).rjust(4)}  {last:<10}  {forged:<10}  {flag}")


def cmd_touch(name):
    p, fm = _find(name)
    _ensure_defaults(fm)
    fm["uses"] = str(int(fm.get("uses", "0") or 0) + 1)
    fm["last-used"] = _today()
    _rewrite(p, fm)
    print(f"ok: {name} uses={fm['uses']} last-used={fm['last-used']}")


def cmd_flag(name, reason=""):
    p, fm = _find(name)
    _ensure_defaults(fm)
    fm["contradicted"] = "true"
    _rewrite(p, fm)
    log = MNEMO_HOME / "logs" / "skill-flags.log"
    log.parent.mkdir(parents=True, exist_ok=True)
    with open(log, "a", encoding="utf-8") as f:
        f.write(f"{datetime.now(timezone.utc).isoformat()} flagged {name}: {reason}\n")
    print(f"ok: {name} flagged contradicted ({reason})")


def cmd_unflag(name):
    p, fm = _find(name)
    _ensure_defaults(fm)
    fm["contradicted"] = "false"
    _rewrite(p, fm)
    print(f"ok: {name} unflagged")


def cmd_gc(apply=False):
    dead, contra = [], []
    for p in _skill_files():
        fm, _, _ = _split(p.read_text(encoding="utf-8"))
        if not _is_forged(fm):
            continue
        _ensure_defaults(fm)
        name = p.parent.name
        if fm.get("contradicted") == "true":
            contra.append(name)
            continue
        if int(fm.get("uses", "0") or 0) == 0:
            age = _age_days(fm.get("forged", _today()))
            if age is not None and age >= GC_DAYS:
                dead.append((name, age))
    if not dead and not contra:
        print(f"gc: nothing to prune (dead>{GC_DAYS}d unused / contradicted)")
        return
    if contra:
        print("contradicted (a later correction conflicts):")
        for n in contra:
            print(f"  - {n}")
    if dead:
        print(f"dead (never used, older than {GC_DAYS}d):")
        for n, age in dead:
            print(f"  - {n}  ({age}d old)")
    if not apply:
        print("\nrun with --apply to move these to ~/.mnemo/pruned/ (revertable)")
        return
    grave = MNEMO_HOME / "pruned"
    grave.mkdir(parents=True, exist_ok=True)
    import shutil
    for n in [c for c in contra] + [d[0] for d in dead]:
        src = SKILLS_DIR / n
        dst = grave / f"{n}.{_today()}"
        shutil.move(str(src), str(dst))
        print(f"pruned {n} -> {dst}")


def main():
    a = sys.argv[1:]
    if not a:
        sys.exit("usage: mnemo-skill list|touch|flag|unflag|gc ...")
    cmd = a[0]
    try:
        if cmd == "list":     cmd_list()
        elif cmd == "touch":  cmd_touch(a[1])
        elif cmd == "flag":   cmd_flag(a[1], a[2] if len(a) > 2 else "")
        elif cmd == "unflag": cmd_unflag(a[1])
        elif cmd == "gc":     cmd_gc(apply=("--apply" in a[1:]))
        else: sys.exit(f"unknown command '{cmd}'")
    except IndexError:
        sys.exit(f"missing argument for '{cmd}'")


if __name__ == "__main__":
    main()
